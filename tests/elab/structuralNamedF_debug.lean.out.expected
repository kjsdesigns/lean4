foo._f : List Nat → List Nat → (zs : List Nat) → List.below zs → List Nat
foo.eq_def : ∀ (xs ys zs : List Nat),
  foo xs ys zs =
    match (xs, ys) with
    | (xs', ys') =>
      match zs with
      | z :: zs => foo xs ys zs
      | x =>
        match ys' with
        | [] => [1]
        | x => [2]
foo.eq_1 : ∀ (xs ys : List Nat) (z : Nat) (zs_2 : List Nat), foo xs ys (z :: zs_2) = foo xs ys zs_2
