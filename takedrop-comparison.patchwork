## Empty/nil conditions

``` lean src/Init/Data/List/TakeDrop.lean:/^theorem drop_eq_nil_iff/../^$/

@[simp]
===
theorem drop_eq_nil_iff {l : List α} {i : Nat} : l.drop i = [] ↔ l.length ≤ i := by
  refine ⟨fun h => ?_, drop_eq_nil_of_le⟩
  induction i generalizing l with
  | zero =>
    simp only [drop] at h
    simp [h]
  | succ i hi =>
    cases l
    · simp
    · simp only [drop] at h
      simpa [Nat.succ_le_succ_iff] using hi h
===

@[simp]
```

Missing: `Array.drop_eq_empty_iff` (`xs.drop i = #[] ↔ xs.size ≤ i`)

``` lean src/Init/Data/Array/TakeDrop.lean:/theorem drop_eq_empty_iff /../^$/
@[simp] theorem drop_eq_empty_iff {xs : Array α} {i : Nat} : xs.drop i = #[] ↔ xs.size ≤ i := by
  constructor
  · intro h
    have := congrArg size h
    simpa [Nat.sub_eq_zero_iff_le] using this
  · exact drop_of_size_le
```

``` lean src/Init/Data/List/TakeDrop.lean:/^theorem take_eq_nil_iff/../^$/

@[simp]
===
theorem take_eq_nil_iff {l : List α} {k : Nat} : l.take k = [] ↔ k = 0 ∨ l = [] := by
  cases l <;> cases k <;> simp [Nat.succ_ne_zero]
===

theorem drop_eq_nil_of_eq_nil : ∀ {as : List α} {i}, as = [] → as.drop i = []
```

Missing: `Array.take_eq_empty_iff` (`xs.take k = #[] ↔ k = 0 ∨ xs = #[]`)

``` lean src/Init/Data/Array/TakeDrop.lean:/theorem take_eq_empty_iff /../^$/
@[simp] theorem take_eq_empty_iff {xs : Array α} {k : Nat} :
    xs.take k = #[] ↔ k = 0 ∨ xs = #[] := by
  rw [← toList_inj, toList_take, ← toList_inj]
  simp [List.take_eq_nil_iff]
```

